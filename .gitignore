# ============================================================
#  CUE-X / StyleSense  –  Root .gitignore
#  Stack: Python (Flask) + Jupyter + React (Vite / TypeScript)
# ============================================================

# ─────────────────────────────────────────
#  PYTHON / FLASK BACKEND
# ─────────────────────────────────────────

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
site-packages/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# ML model artefacts (large binary files – store in cloud/DVC instead)
*.pkl
*.pickle
*.h5
*.hdf5
*.pt
*.pth
*.ckpt
*.model

# Uploaded / processed data files
uploads/
*.csv
!data/samples/StyleSense_Dataset_updated.csv
!frontend/public/samples/StyleSense_Dataset_updated.csv
*.xlsx
*.xls
*.parquet
# Ignore only dataset JSON files
data/*.json
uploads/*.json
# ^ keep tracked JSON configs explicitly if needed:
!cluster_data.json

# Reports & logs
*.log
logs/

# Flask instance / config secrets
instance/
.env
.env.*
config.py
secrets.py

# Coverage / test artefacts
.coverage
htmlcov/
.pytest_cache/
nosetests.xml
coverage.xml

# MyPy / type-checking
.mypy_cache/
.dmypy.json
dmypy.json

# ─────────────────────────────────────────
#  NODE / REACT / VITE FRONTEND
# ─────────────────────────────────────────

# Dependencies
frontend/node_modules/
node_modules/

# Build output
frontend/dist/
frontend/build/

# Vite cache
frontend/.vite/
.vite/

# TypeScript build info
*.tsbuildinfo
frontend/*.tsbuildinfo

# ESLint cache
.eslintcache
frontend/.eslintcache

# Local env files (Vite)
frontend/.env
frontend/.env.local
frontend/.env.*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug / error logs
frontend/build_errors.txt
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─────────────────────────────────────────
#  EDITORS & OS
# ─────────────────────────────────────────

# VS Code (keep shared settings, ignore personal)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# JetBrains IDEs
.idea/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ─────────────────────────────────────────
#  MISC
# ─────────────────────────────────────────

# Heroku / deployment
.heroku/

# Temporary files
*.tmp
*.bak
*.swp
*.swo
